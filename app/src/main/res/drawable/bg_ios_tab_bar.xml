<?xml version="1.0" encoding="utf-8"?>
<!--
  iOS-style tab bar background.
  Frosted glass effect with thin top separator line.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
	<!-- Main background: translucent white (frosted glass) -->
	<item>
		<shape android:shape="rectangle">
			<solid android:color="#F9F9FB" />
		</shape>
	</item>
	<!-- Top separator line -->
	<item
		android:bottom="-1dp"
		android:top="0dp">
		<shape android:shape="rectangle">
			<size android:height="1dp" />
			<solid android:color="#33C6C6C8" />
		</shape>
	</item>
</layer-list>
