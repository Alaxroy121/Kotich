<?xml version="1.0" encoding="utf-8"?>
<!-- iOS 27 bottom sheet background with drag handle area -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
	<!-- Main sheet body -->
	<item>
		<shape android:shape="rectangle">
			<solid android:color="@color/ios27_glass_white_ultra" />
			<corners
				android:topLeftRadius="20dp"
				android:topRightRadius="20dp" />
		</shape>
	</item>
	<!-- Top glass border for depth -->
	<item
		android:top="0dp">
		<shape android:shape="rectangle">
			<stroke
				android:width="0.5dp"
				android:color="@color/ios27_glass_border" />
			<corners
				android:topLeftRadius="20dp"
				android:topRightRadius="20dp" />
			<solid android:color="@android:color/transparent" />
		</shape>
	</item>
</layer-list>
