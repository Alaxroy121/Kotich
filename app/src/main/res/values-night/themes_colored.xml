<?xml version="1.0" encoding="utf-8"?>
<resources>
	<!--
		Liquid (iOS 27) — Night mode override.
		The day version uses ThemeOverlay.Material3.Light which forces light
		textColorPrimary (dark text). In night mode we MUST use the Dark parent
		so android:textColorPrimary resolves to light text on dark backgrounds.
		The ios27_* color resources already have night variants in colors_themed.xml.
	-->
	<style name="ThemeOverlay.Kotatsu.Liquid" parent="ThemeOverlay.Material3.Dark">
		<item name="colorPrimary">@color/ios27_primary</item>
		<item name="colorOnPrimary">@color/ios27_onPrimary</item>
		<item name="colorPrimaryContainer">@color/ios27_primaryContainer</item>
		<item name="colorOnPrimaryContainer">@color/ios27_onPrimaryContainer</item>
		<item name="colorSecondary">@color/ios27_secondary</item>
		<item name="colorOnSecondary">@color/ios27_onSecondary</item>
		<item name="colorSecondaryContainer">@color/ios27_secondaryContainer</item>
		<item name="colorOnSecondaryContainer">@color/ios27_onSecondaryContainer</item>
		<item name="colorTertiary">@color/ios27_tertiary</item>
		<item name="colorOnTertiary">@color/ios27_onTertiary</item>
		<item name="colorTertiaryContainer">@color/ios27_tertiaryContainer</item>
		<item name="colorOnTertiaryContainer">@color/ios27_onTertiaryContainer</item>
		<item name="colorError">@color/ios27_error</item>
		<item name="colorOnError">@color/ios27_on_error</item>
		<item name="colorErrorContainer">@color/ios27_error_container</item>
		<item name="colorOnErrorContainer">@color/ios27_on_error_container</item>
		<item name="android:colorBackground">@color/ios27_background</item>
		<item name="colorOnBackground">@color/ios27_on_background</item>
		<item name="colorSurface">@color/ios27_surface</item>
		<item name="colorOnSurface">@color/ios27_on_surface</item>
		<item name="colorSurfaceVariant">@color/ios27_surface_variant</item>
		<item name="colorOnSurfaceVariant">@color/ios27_on_surface_variant</item>
		<item name="colorOutline">@color/ios27_outline</item>
		<item name="colorOutlineVariant">@color/ios27_outline_variant</item>
		<item name="colorSurfaceInverse">@color/ios27_inverse_surface</item>
		<item name="colorOnSurfaceInverse">@color/ios27_inverse_on_surface</item>
		<item name="colorPrimaryInverse">@color/ios27_inversePrimary</item>
		<item name="colorSurfaceDim">@color/ios27_surface_dim</item>
		<item name="colorSurfaceBright">@color/ios27_surface_bright</item>
		<item name="colorSurfaceContainerLowest">@color/ios27_surface_container_lowest</item>
		<item name="colorSurfaceContainerLow">@color/ios27_surface_container_low</item>
		<item name="colorSurfaceContainer">@color/ios27_surface_container</item>
		<item name="colorSurfaceContainerHigh">@color/ios27_surface_container_high</item>
		<item name="colorSurfaceContainerHighest">@color/ios27_surface_container_highest</item>
		<!-- iOS Tab Bar -->
		<item name="bottomNavigationStyle">@style/Widget.Kotich.iOS.TabBar</item>
	</style>
</resources>
